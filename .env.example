# Supabase Configuration
# Copy this file to .env and fill in your values
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Service Role Key (for Netlify Functions only)
# Get from: Supabase Dashboard → Settings → API → service_role key
# WARNING: Keep this secret! Only use in Netlify environment variables
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe Configuration
# Get from: https://dashboard.stripe.com/test/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key

# Calendly Configuration
# Your default Calendly booking URL (used as fallback if service-specific URL not set)
VITE_CALENDLY_URL=https://calendly.com/your-username/consultation

# Email Configuration (Resend)
# Resend API Key (get from: https://resend.com/api-keys)
RESEND_API_KEY=re_your_resend_api_key
# Admin email for receiving form submissions and alerts
ADMIN_EMAIL=partners@notifications.rivalislaw.com
# From email for sending user notifications (must be verified domain in Resend)
FROM_EMAIL=noreply@notifications.rivalislaw.com

# Application URL (used in email links)
NEXT_PUBLIC_APP_URL=https://rivalislaw.com

# Supabase Storage
# Storage bucket name for partner application documents
SUPABASE_STORAGE_BUCKET=partner-documents

# Stripe Webhook Secret (for payment confirmation)
# Get from: https://dashboard.stripe.com/test/webhooks (after creating webhook)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
