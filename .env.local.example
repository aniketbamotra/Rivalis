# Instructions for migration:
# 1. Rename this file to .env.local
# 2. Fill in your actual values
# 3. All public environment variables must be prefixed with NEXT_PUBLIC_

# Supabase Configuration (Public - these are safe to expose to the client)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Stripe Configuration
# Public key (safe for client-side)
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=your_stripe_public_key

# Secret keys (server-side only - NO NEXT_PUBLIC_ prefix)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Resend Email Configuration (server-side only)
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=noreply@notifications.rivalislaw.com
ADMIN_EMAIL=partners@notifications.rivalislaw.com

# Application URL (public - used in email links and redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Storage
# Storage bucket name for partner application documents
SUPABASE_STORAGE_BUCKET=partner-documents

# Emergency consultation email (public)
NEXT_PUBLIC_EMERGENCY_EMAIL=contact@rivalislaw.com
